<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="487.0" prefWidth="606.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.dio.tictactoe.StartController">
   <children>
      <ImageView fitHeight="574.0" fitWidth="873.0" layoutX="-267.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@assets/background.jpg" />
         </image>
      </ImageView>

      <ImageView fitHeight="211.0" fitWidth="352.0" layoutX="127.0" layoutY="60.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@assets/Titulo.png" />
         </image>
      </ImageView>

      <Button layoutX="203.0" layoutY="206.0" onAction="#clicouStart" style="-fx-background-color: transparent; -fx-cursor: hand;">
         <graphic>
            <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@assets/stardbtn.png" />
               </image>
               <effect>
                  <DropShadow />
               </effect>
            </ImageView>
         </graphic>
      </Button>

      <TextField fx:id="campoIp" layoutX="210.0" layoutY="258.0" prefHeight="41.0" prefWidth="202.0" promptText="Digite o IP aqui..." style="-fx-background-color: rgba(128, 0, 128, 0.7); -fx-font-size:20px;  -fx-text-fill: white; -fx-prompt-text-fill: #cccccc; -fx-border-color: white; -fx-border-radius: 5; -fx-background-radius: 5; -fx-alignment: left;" visible="false">
         <font>
            <Font name="System Bold" size="15.0" />
         </font>
      </TextField>

      <Button fx:id="btnIpConfig" layoutX="203.0" layoutY="255.0" onAction="#clicouIpConfig" style="-fx-background-color: transparent; -fx-cursor: hand;">
         <graphic>
            <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@assets/ipconfigbtn.png" />
               </image>
               <effect>
                  <DropShadow />
               </effect>
            </ImageView>
         </graphic>
      </Button>

      <Button layoutX="203.0" layoutY="304.0" onAction="#clicouInfo" style="-fx-background-color: transparent; -fx-cursor: hand;">
         <graphic>
            <ImageView fitHeight="87.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@assets/infobtn.png" />
               </image>
               <effect>
                  <DropShadow />
               </effect>
            </ImageView>
         </graphic>
      </Button>
   </children>
</AnchorPane>
